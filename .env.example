# =========================================
# VELORA Phase 1 — Environment Variables
# =========================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# -----------------------------------------
# Telegram Bot
# -----------------------------------------
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# -----------------------------------------
# SerpAPI
# -----------------------------------------
# Sign up at https://serpapi.com/ to get an API key
SERPAPI_API_KEY=your_serpapi_key_here

# -----------------------------------------
# Google Sheets
# -----------------------------------------
# Create a service account and share your sheet with it
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_SHEET_NAME=Leads

# -----------------------------------------
# Google Service Account Credentials
# -----------------------------------------
# Path to the downloaded JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./credentials.json
