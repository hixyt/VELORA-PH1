    {
      "parameters": {
        "jsCode": "const msg = $input.first().json?.message?.text?.toLowerCase().trim() || '';\n\nconst cityMap = {\n  'nagpur': 'cafes+restaurants+salons+Nagpur&ll=@21.1458,79.0882,14z',\n  'pune': 'cafes+restaurants+salons+Pune&ll=@18.5204,73.8567,14z',\n  'mumbai': 'cafes+restaurants+salons+Mumbai&ll=@19.0760,72.8777,14z',\n  'delhi': 'cafes+restaurants+salons+Delhi&ll=@28.6139,77.2090,14z',\n  'bangalore': 'cafes+restaurants+salons+Bangalore&ll=@12.9716,77.5946,14z',\n  'hyderabad': 'cafes+restaurants+salons+Hyderabad&ll=@17.3850,78.4867,14z',\n  'start': 'cafes+restaurants+salons+Nagpur&ll=@21.1458,79.0882,14z'\n};\n\nconst validCommands = Object.keys(cityMap);\nconst matched = validCommands.find(cmd => msg.includes(cmd));\n\nif (!matched) {\n  return [{\n    json: {\n      triggered: false,\n      message: '❌ Send a city name:\\nnagpur, pune, mumbai, delhi, bangalore, hyderabad'\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    triggered: true,\n    city: matched.charAt(0).toUpperCase() + matched.slice(1),\n    searchQuery: cityMap[matched],\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
