      "id": "74f38f7f-145d-4e0e-9338-5a459c5df1f2",
      "name": "Scrape Local Businesses",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        336,
        -368
      ],
      "notes": "FREE alternative: Replace with SerpAPI Google Maps free tier (100 searches/month) or Apify Google Maps Scraper (free tier). See PART 7 notes."
    },
    {
      "parameters": {
        "jsCode": "const businesses = $input.first().json?.local_results || [];\nconst dayOffset = new Date().getDate() % 5;\nconst rotated = [...businesses.slice(dayOffset), ...businesses.slice(0, dayOffset)];\n\nif (rotated.length === 0) {\n  return [{ json: { error: 'No businesses found', count: 0 } }];\n}\n\nreturn rotated.slice(0, 5).map(b => {\n  const noWebsite = !b.website || b.website.trim() === '';\n  const lowRating = b.rating > 0 && b.rating < 4.0;\n  const hasPhone = !!(b.phone);\n  const reviewCount = b.reviews || 0;\n\n  let score = 0;\n  if (noWebsite) score += 4;\n  if (lowRating) score += 3;\n  if (!hasPhone) score += 2;\n  if (reviewCount < 50) score += 1;\n\n  return {\n    json: {\n      title: b.title || 'Unknown',\n      address: b.address || '',\n      rating: b.rating || 'No rating',\n      phone: b.phone || 'N/A',\n      website: b.website || 'No Website',\n      category: b.type || 'Business',\n      place_id: b.place_id || '',\n      maps_link: b.place_id ? 'https://maps.google.com/?cid=' + b.place_id : 'N/A',\n      lead_score: score + '/10',\n      priority: score >= 6 ? '🔥 Hot' : score >= 3 ? '⭐ Warm' : '❄️ Cold'\n    }\n  };\n});"
      },
